    <twig:layout:PageHeader title="New Project" :breadcrumbs="breadcrumbs" />

    <div class="page-content">
        <div class="card" style="max-width: 680px;">
            <div class="card-body">
                <twig:project:ProjectForm />
            </div>
        </div>
    </div>
{% endblock %}
