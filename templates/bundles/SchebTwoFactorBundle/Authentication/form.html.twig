{% extends 'base.html.twig' %}

{% block title %}Two-Factor Authentication — WebDream Manager{% endblock %}

{% block body %}
    <div class="[min-height:100dvh] flex items-center justify-center [background-color:var(--color-surface)]">
        <div class="w-full [max-width:400px] [padding:2rem]">
            <div class="[margin-bottom:2rem] text-center">
                <div
                    class="[font-family:var(--font-headline)] [font-size:1.25rem] [font-weight:700] [color:var(--color-on-surface)] [margin-bottom:0.25rem]">
                    WebDream Manager
                </div>
                <div class="text-sm [color:var(--color-on-surface-variant)]">Two-factor authentication</div>
            </div>

            {% if authenticationError %}
                <div
                    class="[padding:0.75rem_1rem] [background-color:var(--color-error-container)] [color:var(--color-on-error-container)] text-sm [margin-bottom:1rem]">
                    {{ authenticationError|trans({}, 'SchebTwoFactorBundle') }}
                </div>
            {% endif %}

            <form method="post" action="{{ checkPathUrl ?? path(checkPathRoute) }}">
                {% if isCsrfProtectionEnabled %}
                    <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
                {% endif %}

                <div class="[margin-bottom:0.5rem] text-sm [color:var(--color-on-surface-variant)]">
                    Enter the code from your authenticator app or the one sent to your email.
                </div>

                <div class="[margin-bottom:1.5rem]">
                    <label class="form-label" for="2fa-code">Authentication Code</label>
                    <input id="2fa-code"
                           type="text"
                           name="{{ authCodeParameterName }}"
                           class="form-input [font-family:var(--font-mono)] [font-size:1.25rem] [letter-spacing:0.15em] text-center"

                           autocomplete="one-time-code"
                           inputmode="numeric"
                           maxlength="8"
                           autofocus
                           required>
                </div>

                <button type="submit" class="btn btn-primary w-full justify-center">
                    Verify
                </button>

                {% if displayTrustedOption %}
                    <label
                        class="flex items-center [gap:0.5rem] [margin-top:1rem] text-sm [color:var(--color-on-surface-variant)] cursor-pointer">
                        <input type="checkbox" name="{{ trustedParameterName }}">
                        Trust this device for 30 days
                    </label>
                {% endif %}
            </form>

            <div
                class="[margin-top:1.5rem] [padding-top:1rem] [border-top:1px_solid_var(--color-outline-variant)] text-center">
                <a href="{{ logoutPath }}"
                   class="text-[0.8125rem] [color:var(--color-on-surface-variant)] [text-decoration:none]">
                    Cancel and return to login
                </a>
            </div>
        </div>
    </div>
{% endblock %}
