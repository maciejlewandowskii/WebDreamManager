{% extends 'layout.html.twig' %}

{% block title %}New Customer — WebDream Manager{% endblock %}

{% block content %}
    {% set breadcrumbs = [{label: 'Customers', url: path('app_customer_index')}, {label: 'New'}] %}
    <twig:layout:PageHeader title="New Customer" :breadcrumbs="breadcrumbs" />

    <div class="page-content">
        <div class="card" style="max-width: 680px;">
            <div class="card-body">
                <twig:customer:CustomerForm />
            </div>
        </div>
    </div>
{% endblock %}
