{% extends 'layout.html.twig' %}

{% block title %}Dashboard — WebDream Manager{% endblock %}

{% block content %}
    <twig:layout:PageHeader title="Dashboard" />

    <div class="page-content">
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem;">
            <div class="stat-card">
                <div class="stat-label">Active Projects</div>
                <div class="stat-value">{{ activeProjects }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Open Invoices</div>
                <div class="stat-value">{{ openInvoices }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Pending Quotes</div>
                <div class="stat-value">{{ pendingQuotes }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">This Month (h)</div>
                <div class="stat-value">{{ monthHours|number_format(1) }}</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="card">
                <div class="card-header">
                    <div style="font-size: 0.875rem; font-weight: 500; color: var(--color-on-surface);">Recent Invoices</div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr><th>Number</th><th>Customer</th><th>Amount</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        {% for invoice in recentInvoices %}
                            <tr>
                                <td style="font-family: var(--font-mono); font-size: 0.8125rem;">
                                    <a href="{{ path('app_invoice_edit', {id: invoice.id}) }}" style="color: var(--color-on-surface); text-decoration: none;">{{ invoice.number }}</a>
                                </td>
                                <td style="color: var(--color-on-surface-variant);">{{ invoice.customer.name }}</td>
                                <td style="font-family: var(--font-mono); font-size: 0.8125rem;">{{ invoice.grossTotal|number_format(2, '.', ' ') }} {{ invoice.currency }}</td>
                                <td><span class="badge badge-{{ invoice.status.color }}">{{ invoice.status.value }}</span></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" style="text-align:center; color: var(--color-on-surface-variant); padding: 2rem;">No invoices yet.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="card">
                <div class="card-header">
                    <div style="font-size: 0.875rem; font-weight: 500; color: var(--color-on-surface);">Recent Time Records</div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr><th>Date</th><th>Title</th><th>Project</th><th>Spent</th></tr>
                    </thead>
                    <tbody>
                        {% for record in recentTimeRecords %}
                            <tr>
                                <td style="font-family: var(--font-mono); font-size: 0.8125rem; white-space: nowrap;">{{ record.date|date('d.m') }}</td>
                                <td style="font-size: 0.875rem;">{{ record.title|u.truncate(40, '…') }}</td>
                                <td style="color: var(--color-on-surface-variant); font-size: 0.8125rem;">{{ record.project.name }}</td>
                                <td style="font-family: var(--font-mono); font-size: 0.8125rem;">{{ record.spentHours }}h</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" style="text-align:center; color: var(--color-on-surface-variant); padding: 2rem;">No records yet.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
