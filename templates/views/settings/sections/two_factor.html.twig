<twig:Card>
    <twig:CardHeader>
        <div class="text-sm font-semibold [color:var(--color-on-surface)]">Two-Factor Authentication</div>
    </twig:CardHeader>
    <twig:CardBody class="flex flex-col [gap:1rem]">

        <div class="flex items-center justify-between [padding:1rem] [border:1px_solid_var(--color-outline-variant)]">
            <div>
                <div class="text-sm font-medium [color:var(--color-on-surface)] flex items-center [gap:0.375rem]">
                    {{ ux_icon('tabler:mail', {class: 'w-4 h-4'}) }} Email Code
                </div>
                <div class="text-[0.8125rem] [color:var(--color-on-surface-variant)] [margin-top:0.25rem]">
                    Receive a one-time code by email on each login.
                </div>
            </div>
            <form method="post" action="{{ path('app_settings_2fa_email') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('2fa_email') }}">
                {% if app.user.emailAuthEnabled %}
                    <twig:Button variant="ghost" size="sm" type="submit" class="[color:var(--color-error)]">
                        Disable
                    </twig:Button>
                {% else %}
                    <twig:Button variant="primary" size="sm" type="submit">
                        Enable
                    </twig:Button>
                {% endif %}
            </form>
        </div>

        <div class="[padding:1rem] [border:1px_solid_var(--color-outline-variant)]">
            <div
                class="flex items-center justify-between{% if app.user.totpAuthenticationEnabled or totp_pending_secret %} [margin-bottom:1rem]{% endif %}">
                <div>
                    <div class="text-sm font-medium [color:var(--color-on-surface)] flex items-center [gap:0.375rem]">
                        {{ ux_icon('tabler:device-mobile', {class: 'w-4 h-4'}) }} Authenticator App
                    </div>
                    <div class="text-[0.8125rem] [color:var(--color-on-surface-variant)] [margin-top:0.25rem]">
                        Use Google Authenticator, Authy, or any TOTP app.
                    </div>
                </div>
                <div class="flex [gap:0.5rem] items-center">
                    {% if app.user.totpAuthenticationEnabled %}
                        <twig:Badge variant="success">Active</twig:Badge>
                        <form method="post" action="{{ path('app_settings_2fa_totp_disable') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('totp_disable') }}">
                            <twig:Button variant="ghost" size="sm" type="submit" class="[color:var(--color-error)]">
                                Remove
                            </twig:Button>
                        </form>
                    {% elseif totp_pending_secret %}
                        <twig:Badge variant="warning">Setup in progress</twig:Badge>
                        <form method="post" action="{{ path('app_settings_2fa_totp_cancel') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('totp_cancel') }}">
                            <twig:Button variant="ghost" size="sm" type="submit">
                                Cancel
                            </twig:Button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('app_settings_2fa_totp_generate') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('totp_generate') }}">
                            <twig:Button variant="primary" size="sm" type="submit">
                                Set up
                            </twig:Button>
                        </form>
                    {% endif %}
                </div>
            </div>

            {% if totp_pending_secret and totp_qr_uri %}
                <div class="flex [gap:2rem] items-start">
                    <img src="{{ totp_qr_uri }}" alt="QR Code"
                         class="[width:160px] [height:160px] [border:1px_solid_var(--color-outline-variant)] shrink-0">
                    <div class="flex-1">
                        <p class="text-sm [color:var(--color-on-surface)] [margin-bottom:0.75rem]">
                            Scan this QR code with your authenticator app, then enter the 6-digit code below to confirm.
                        </p>
                        <p class="text-xs [color:var(--color-on-surface-variant)] [font-family:var(--font-mono)] [margin-bottom:1rem] [word-break:break-all]">
                            Secret: {{ totp_pending_secret }}
                        </p>
                        <form method="post" action="{{ path('app_settings_2fa_totp_enable') }}"
                              class="flex [gap:0.5rem] items-end">
                            <input type="hidden" name="_token" value="{{ csrf_token('totp_enable') }}">
                            <div class="flex-1">
                                <label class="form-label" for="totp_code">Verification Code</label>
                                <input type="text" id="totp_code" name="totp_code"
                                       class="form-input [letter-spacing:0.2em] [font-family:var(--font-mono)]"
                                       placeholder="000000" maxlength="6" autocomplete="one-time-code"
                                >
                            </div>
                            <twig:Button variant="primary" type="submit"
                                         class="[height:max-content] [padding-block:0.5rem]">
                                Verify &amp; Enable
                            </twig:Button>
                        </form>
                    </div>
                </div>
            {% endif %}
        </div>

    </twig:CardBody>
</twig:Card>
