<twig:Card data-controller="passkey"
           data-passkey-register-options-url-value="{{ path('app_settings_passkey_register_options') }}"
           data-passkey-register-url-value="{{ path('app_settings_passkey_register') }}">
    <twig:CardHeader>
        <div class="flex items-center justify-between w-full gap-3">
            <div class="text-sm font-semibold [color:var(--color-on-surface)]">Passkeys</div>
            <twig:Button variant="primary" size="sm" type="button" data-action="passkey#register">
                {{ ux_icon('tabler:plus', {class: 'w-4 h-4'}) }} Add passkey
            </twig:Button>
        </div>
    </twig:CardHeader>
    <twig:CardBody>
        {% if passkeys is defined and passkeys|length > 0 %}
            <twig:DataTable>
                <twig:block name="head">
                    <th>Name</th>
                    <th>Created</th>
                    <th>Last used</th>
                    <th></th>
                </twig:block>

                {% for key in passkeys %}
                    <tr>
                        <td class="text-sm">{{ key.name }}</td>
                        <td class="text-[0.8125rem] [color:var(--color-on-surface-variant)] [font-family:var(--font-mono)]">{{ key.createdAt|date('d.m.Y') }}</td>
                        <td class="text-[0.8125rem] [color:var(--color-on-surface-variant)] [font-family:var(--font-mono)]">{{ key.lastUsedAt ? key.lastUsedAt|date('d.m.Y') : '—' }}</td>
                        <td class="text-right">
                            <form method="post" action="{{ path('app_settings_passkey_delete', {id: key.id}) }}"
                                  class="inline">
                                <twig:Button variant="ghost" size="sm" type="submit" class="[color:var(--color-error)]">
                                    Remove
                                </twig:Button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </twig:DataTable>
        {% else %}
            <div class="text-center [padding:2rem_1rem] [color:var(--color-on-surface-variant)]">
                <div
                    class="flex justify-center [margin-bottom:0.5rem]">{{ ux_icon('tabler:fingerprint', {class: 'h-8 w-8 opacity-40'}) }}</div>
                <div class="text-sm">No passkeys registered yet.</div>
                <div class="text-[0.8125rem] [margin-top:0.25rem]">Use your device's biometrics or security key to sign
                    in without a password.
                </div>
            </div>
        {% endif %}
    </twig:CardBody>

    <dialog data-passkey-target="nameDialog" class="app-dialog">
        <div class="modal-header">
            <span class="modal-title">Name this passkey</span>
            <button type="button" class="modal-close" data-action="passkey#cancelName">&#x2715;</button>
        </div>
        <div class="[padding:1.5rem]">
            <p class="text-sm [color:var(--color-on-surface-variant)] [margin:0_0_1rem]">
                Give it a name to identify it later, e.g. "MacBook Touch ID".
            </p>
            <label class="form-label" for="passkey-name-input">Name</label>
            <input type="text" id="passkey-name-input" class="form-input [margin-bottom:1.5rem]"
                   data-passkey-target="nameInput"
                   placeholder="e.g. MacBook Touch ID"
                   maxlength="100"
            >
            <div class="flex [justify-content:flex-end] [gap:0.5rem]">
                <twig:Button variant="ghost" type="button" data-action="passkey#cancelName">
                    Cancel
                </twig:Button>
                <twig:Button variant="primary" type="button" data-action="passkey#confirmName">
                    Continue
                </twig:Button>
            </div>
        </div>
    </dialog>
</twig:Card>
