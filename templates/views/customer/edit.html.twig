<twig:Modal>
    {{ form_start(form, {attr: {'data-turbo-frame': '_top'}}) }}
    <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">{{ form_row(form.name) }}</div>
        <div>{{ form_row(form.email) }}</div>
        <div>{{ form_row(form.phone) }}</div>
        <div>{{ form_row(form.company) }}</div>
        <div>{{ form_row(form.taxId) }}</div>
        <div>{{ form_row(form.hourlyRate) }}</div>
        <div>{{ form_row(form.status) }}</div>
        <div>{{ form_row(form.pdfColorMode) }}</div>
        <div class="col-span-2">{{ form_row(form.notes) }}</div>
    </div>
    <div class="mt-6 flex justify-end gap-2">
        <twig:Button variant="ghost" type="button" data-action="modal#close">
            Cancel
        </twig:Button>
        {{ form_widget(form.save) }}
    </div>
    {{ form_end(form) }}
</twig:Modal>
