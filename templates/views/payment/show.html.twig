{% extends 'base.html.twig' %}

{% block title %}Invoice {{ invoice.number }} — Payment{% endblock %}
{% block body_class %}payment-layout{% endblock %}

{% block body %}
    <div class="payment-topbar">
        <span class="payment-topbar__brand">{{ company_name }}</span>
        <span class="payment-topbar__badge">Secure Checkout</span>
    </div>

    <div class="payment-page">

        {# ── Invoice preview ── #}
        <div class="payment-invoice">
            <div class="payment-inv-header">
                <div>
                    <div class="payment-inv-from-label">From</div>
                    <div class="payment-inv-from-name">{{ company_name }}</div>
                    {% if company_email %}
                        <div class="payment-inv-from-sub">{{ company_email }}</div>
                    {% endif %}
                </div>
                <div>
                    <div class="payment-inv-num-label">Invoice</div>
                    <div class="payment-inv-number">{{ invoice.number }}</div>
                    {% set s = invoice.status.value %}
                    <span
                        class="payment-inv-status payment-inv-status--{{ s in ['issued','paid','overdue'] ? s : 'default' }}">
                    {{ invoice.status.label() }}
                </span>
                </div>
            </div>

            <div class="payment-inv-body">
                <div class="payment-inv-meta">
                    <div>
                        <div class="payment-inv-meta-label">Billed to</div>
                        <div class="payment-inv-meta-value">{{ invoice.customer.name }}</div>
                        {% if invoice.customer.email %}
                            <div class="payment-inv-meta-sub">{{ invoice.customer.email }}</div>
                        {% endif %}
                        {% if invoice.customer.company %}
                            <div class="payment-inv-meta-sub">{{ invoice.customer.company }}</div>
                        {% endif %}
                    </div>
                    <div class="payment-inv-meta-dates">
                        <div>
                            <div class="payment-inv-meta-label">Issue date</div>
                            <div class="payment-inv-meta-value">{{ invoice.issuedAt|date('d.m.Y') }}</div>
                        </div>
                        <div>
                            <div class="payment-inv-meta-label">Due date</div>
                            <div class="payment-inv-meta-value">{{ invoice.dueAt|date('d.m.Y') }}</div>
                        </div>
                    </div>
                </div>

                <hr class="payment-inv-divider">

                <table class="payment-items">
                    <thead>
                    <tr>
                        <th style="width:46%">Description</th>
                        <th class="r" style="width:8%">Qty</th>
                        <th class="r" style="width:14%">Unit price</th>
                        <th class="r" style="width:8%">Tax</th>
                        <th class="r" style="width:12%">Net</th>
                        <th class="r" style="width:12%">Gross</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in invoice.items %}
                        <tr>
                            <td class="desc">{{ item.description }}</td>
                            <td class="r">{{ item.quantity }}</td>
                            <td class="r">{{ item.unitPrice|number_format(2, '.', ' ') }}</td>
                            <td class="r">{{ item.taxRate }}%</td>
                            <td class="r">{{ item.netTotal|number_format(2, '.', ' ') }}</td>
                            <td class="r">{{ item.grossTotal|number_format(2, '.', ' ') }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>

                <div class="payment-totals">
                    <div class="payment-total-row">
                        <span class="lbl">Net total</span>
                        <span
                            class="amt">{{ invoice.netTotal|number_format(2, '.', ' ') }} {{ invoice.currency }}</span>
                    </div>
                    <div class="payment-total-row">
                        <span class="lbl">VAT</span>
                        <span
                            class="amt">{{ invoice.taxTotal|number_format(2, '.', ' ') }} {{ invoice.currency }}</span>
                    </div>
                    <div class="payment-total-row grand">
                        <span class="lbl">Total due</span>
                        <span
                            class="amt">{{ invoice.grossTotal|number_format(2, '.', ' ') }} {{ invoice.currency }}</span>
                    </div>
                </div>

                {% if invoice.notes %}
                    <div class="payment-inv-notes">{{ invoice.notes }}</div>
                {% endif %}
            </div>
        </div>

        {# ── Payment panel ── #}
        <div class="payment-panel-sticky">
            <div class="payment-panel-card">
                <div class="payment-panel-header">
                    <svg class="payment-panel-header__icon" width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <span class="payment-panel-header__text">Secure payment</span>
                </div>

                <div class="payment-panel-amount">
                    <div class="payment-panel-amount__label">Amount due</div>
                    <div class="payment-panel-amount__value">
                        {{ invoice.grossTotal|number_format(2, '.', ' ') }} {{ invoice.currency }}
                    </div>
                </div>

                {% if alreadyPaid %}
                    <div class="payment-panel-paid">
                        <div class="payment-panel-paid__icon">✓</div>
                        <div class="payment-panel-paid__title">Invoice paid</div>
                        <div class="payment-panel-paid__sub">This invoice has already been paid.<br>Thank you!</div>
                    </div>
                {% elseif not stripeEnabled %}
                    <div class="payment-panel-paid">
                        <div class="payment-panel-paid__icon">ℹ</div>
                        <div class="payment-panel-paid__title">Payment unavailable</div>
                        <div class="payment-panel-paid__sub">Online card payment is not enabled.<br>Please contact us for payment instructions.</div>
                    </div>
                {% elseif paymentConfig.type == 'stripe' %}
                    {% include 'ui/external/stripe_payment.html.twig' with {
                        config: paymentConfig,
                        sessionUrl: path('app_payment_session', {token: invoice.paymentToken}),
                        returnUrl: url('app_payment_return', {token: invoice.paymentToken})
                    } only %}
                {% endif %}
            </div>
        </div>

    </div>
{% endblock %}
