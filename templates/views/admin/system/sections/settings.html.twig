<form method="post" action="{{ path('app_admin_system_settings_save') }}" class="flex flex-col [gap:1.5rem]">

    {% for group_key, fields in groups %}
        <twig:Card>
            <twig:CardHeader>
                <div class="text-sm font-semibold [color:var(--color-on-surface)]">{{ group_labels[group_key] ?? group_key|title }}</div>
            </twig:CardHeader>
            <twig:CardBody>
                <div class="flex flex-col [gap:1rem]">
                    {% for key, field in fields %}
                        <div class="flex flex-col [gap:0.375rem]">
                            <label class="text-xs font-medium [color:var(--color-on-surface-variant)]">
                                {{ field.label }}
                                <span class="font-mono [opacity:0.5] [margin-left:0.25rem]">{{ key }}</span>
                            </label>

                            {% if field.type == 'boolean' %}
                                <label class="flex items-center [gap:0.5rem] cursor-pointer">
                                    <input type="checkbox"
                                           name="settings[{{ key }}]"
                                           value="1"
                                           {{ field.value == '1' ? 'checked' : '' }}
                                           class="form-checkbox">
                                    <span class="text-sm [color:var(--color-on-surface-variant)]">Enabled</span>
                                </label>
                            {% elseif field.secret %}
                                <input type="text"
                                       name="settings[{{ key }}]"
                                       value=""
                                       autocomplete="off"
                                       placeholder="{{ field.hasValue ? '••••••••  (set — enter new value to change)' : 'Not configured' }}"
                                       class="form-input text-sm font-mono">
                            {% else %}
                                <input type="text"
                                       name="settings[{{ key }}]"
                                       value="{{ field.value }}"
                                       autocomplete="off"
                                       class="form-input text-sm font-mono">
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </twig:CardBody>
        </twig:Card>
    {% endfor %}

    <div class="flex items-start [gap:0.75rem] [padding:0.75rem_1rem] rounded [background:var(--color-surface-variant)]">
        {{ ux_icon('tabler:info-circle', {class: 'w-4 h-4 shrink-0 [color:var(--color-primary)] [margin-top:1px]'}) }}
        <p class="text-xs [color:var(--color-on-surface-variant)] [line-height:1.6]">
            Secret values (keys, tokens, DSNs) are never displayed. Leave the field blank to keep the current value.
            Changes to DSN or key values take effect after the container restarts.
            Database, secret, and domain settings cannot be changed here.
        </p>
    </div>

    <div class="flex [justify-content:flex-end]">
        <twig:Button variant="primary" type="submit">Save Settings</twig:Button>
    </div>
</form>
