<div class="flex flex-col [gap:1.5rem]">

    <twig:Card>
        <twig:CardHeader>
            <div class="text-sm font-semibold [color:var(--color-on-surface)]">Log Retention</div>
        </twig:CardHeader>
        <twig:CardBody>
            <div class="flex items-center justify-between [padding:0.75rem_0] [border-bottom:1px_solid_var(--color-outline-variant)]">
                <span class="text-sm [color:var(--color-on-surface-variant)]">Total log entries</span>
                <span class="text-sm font-mono font-medium [color:var(--color-on-surface)]">{{ log_count }}</span>
            </div>
            <div class="flex items-center justify-between [padding:0.75rem_0]">
                <div>
                    <div class="text-sm [color:var(--color-on-surface)]">Purge old entries</div>
                    <div class="text-xs [color:var(--color-on-surface-variant)] [margin-top:0.25rem]">
                        Permanently removes log entries older than the selected period.
                    </div>
                </div>
                <form method="post"
                      action="{{ path('app_admin_log_purge') }}"
                      class="flex items-center gap-2"
                      data-controller="delete-confirm"
                      data-delete-confirm-title-value="Purge Log Entries"
                      data-delete-confirm-message-value="All log entries older than the selected period will be permanently deleted. This cannot be undone."
                      data-action="submit->delete-confirm#submit">
                    <input type="hidden" name="_token" value="{{ csrf_token('purge_logs') }}">
                    <div class="w-36">
                        <select name="days" class="form-select">
                            <option value="7">7 days</option>
                            <option value="30" selected>30 days</option>
                            <option value="90">90 days</option>
                            <option value="180">180 days</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-destructive btn-sm shrink-0">
                        {{ ux_icon('tabler:trash', {class: 'w-4 h-4'}) }}
                        Purge
                    </button>
                </form>
            </div>
        </twig:CardBody>
    </twig:Card>

</div>
