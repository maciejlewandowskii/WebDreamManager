<twig:Modal>
    {{ form_start(form, {attr: {'data-turbo-frame': '_top'}}) }}

    <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">{{ form_row(form.email) }}</div>
        <div class="col-span-2">{{ form_row(form.fullName) }}</div>
        <div>{{ form_row(form.role) }}</div>
        <div class="flex flex-col justify-center">
            <div class="form-label">Status</div>
            <label class="toggle-label">
                {{ form_widget(form.isActive, {attr: {class: 'toggle-input'}}) }}
                <span class="toggle-track"></span>
                <span class="text-sm [color:var(--color-on-surface)]">Active</span>
            </label>
        </div>
    </div>

    <div class="[margin-top:1rem] text-xs [color:var(--color-on-surface-variant)] [border:1px_solid_var(--color-outline-variant)] [border-radius:0.375rem] [padding:0.625rem_0.75rem] flex items-center [gap:0.5rem]">
        {{ ux_icon('tabler:mail', {class: 'w-4 h-4 flex-shrink-0'}) }}
        An invitation email with account setup instructions will be sent to the provided address.
    </div>

    <div class="mt-6 flex justify-end gap-2">
        <twig:Button variant="ghost" type="button" data-action="modal#close">Cancel</twig:Button>
        <twig:Button variant="primary" type="submit">Create &amp; Send Invite</twig:Button>
    </div>

    {{ form_end(form) }}
</twig:Modal>
