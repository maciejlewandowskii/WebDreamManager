{% extends 'base.html.twig' %}

{% block title %}Two-Factor Authentication — WebDream Manager{% endblock %}

{% block body %}
    <div class="[max-width:600px] [margin:0_auto] [padding:2rem] [font-family:var(--font-body,_sans-serif)]">
        <p class="[font-size:1rem] [color:#333]">
            Your WebDream Manager authentication code:
        </p>
        <p class="[font-size:2rem] [font-weight:700] [letter-spacing:0.25em] [color:#111]">
            {{ code }}
        </p>
        <p class="text-sm [color:#666]">
            This code expires in 10 minutes. Do not share it with anyone.
        </p>
    </div>
{% endblock %}
