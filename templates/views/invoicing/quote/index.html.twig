{% extends 'layout.html.twig' %}

{% block title %}Quotes — WebDream Manager{% endblock %}

{% block content %}
    {% set actions %}
        <twig:Button variant="primary" href="{{ path('app_quote_new') }}">
            {{ ux_icon('tabler:plus', {class: 'w-4 h-4'}) }}
            New Quote
        </twig:Button>
    {% endset %}
    <twig:layout:PageHeader title="Quotes" :actions="actions"/>

    <div class="surface">
        {{ component('QuoteList') }}
    </div>
{% endblock %}
