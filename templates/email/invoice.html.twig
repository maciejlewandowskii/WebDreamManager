{% extends 'email/layout.html.twig' %}

{% block email_header %}
    <table>
        <tr>
            <td style="vertical-align:middle;">
                <div class="company-name">{{ company_name }}</div>
                {% if company_email %}
                    <div class="company-email">{{ company_email }}</div>
                {% endif %}
            </td>
            <td style="vertical-align:middle;">
                <div class="doc-type">INVOICE</div>
                <div class="doc-number">{{ invoice.number }}</div>
            </td>
        </tr>
    </table>
{% endblock %}

{% block email_body %}
    <p style="color: #ffffff; font-weight: 500;">Dear {{ invoice.customer.name }},</p>
    <p>Please find your invoice attached to this email.</p>

    <table class="summary-table">
        <tr>
            <td class="label">Invoice number</td>
            <td class="val">{{ invoice.number }}</td>
        </tr>
        <tr>
            <td class="label">Issue date</td>
            <td class="val">{{ invoice.issuedAt|date('d.m.Y') }}</td>
        </tr>
        <tr>
            <td class="label">Due date</td>
            <td class="val">{{ invoice.dueAt|date('d.m.Y') }}</td>
        </tr>
        {% if invoice.bankAccount %}
            <tr>
                <td class="label">Bank account</td>
                <td class="val" style="font-family: monospace;">{{ invoice.bankAccount }}</td>
            </tr>
        {% endif %}
        <tr class="total-row">
            <td>Total due</td>
            <td>{{ invoice.grossTotal|number_format(2, '.', ' ') }} {{ invoice.currency }}</td>
        </tr>
    </table>

    {% if paymentUrl %}
        <div class="btn-container">
            <a href="{{ paymentUrl }}" class="btn">Pay now &rarr;</a>
            <span class="secure-text">Secure payment powered by Stripe</span>
        </div>
    {% endif %}

    <p style="margin-bottom: 8px;">If you have any questions, please reply to this email.</p>
    <p style="margin-bottom: 0;">Best regards,<br><strong style="color:#ffffff;">{{ company_name }}</strong></p>
{% endblock %}

{% block email_footer %}
    {{ company_name }}{% if company_email %} &bull; {{ company_email }}{% endif %}
{% endblock %}
