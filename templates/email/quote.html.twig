<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: #09090b; margin: 0; padding: 2rem 1rem; color: #e4e4e7; }
        .card { background: #18181b; max-width: 580px; margin: 0 auto; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.4); border: 1px solid #27272a; }
        .header { background: #18181b; padding: 2rem; border-bottom: 1px solid #27272a; display: flex; justify-content: space-between; align-items: center; }
        .header table { width: 100%; border-collapse: collapse; }
        .company-name { font-size: 1.125rem; font-weight: 700; color: #ffffff; }
        .company-email { font-size: 0.875rem; color: #a1a1aa; margin-top: 2px; }
        .doc-type { font-size: 1.25rem; font-weight: 700; color: #ffffff; letter-spacing: 0.05em; text-align: right; }
        .doc-number { font-size: 0.875rem; color: #a1a1aa; margin-top: 3px; text-align: right; }
        .body { padding: 2.5rem; }
        p { font-size: 0.9375rem; color: #a1a1aa; line-height: 1.6; margin: 0 0 1.25rem; }
        strong { color: #e4e4e7; }
        .summary-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin-bottom: 2rem; border: 1px solid #27272a; border-radius: 8px; overflow: hidden; }
        .summary-table td { padding: 12px 16px; border-bottom: 1px solid #27272a; }
        .summary-table tr:last-child td { border-bottom: none; }
        .summary-table .label { background: #1f1f22; font-weight: 600; color: #e4e4e7; width: 40%; }
        .summary-table .val { color: #a1a1aa; }
        .summary-table .total-row td { border-top: 2px solid #27272a; font-size: 1rem; color: #ffffff; background: #1f1f22; font-weight: 700; }
        .btn { display: inline-block; background: #6366f1; color: #ffffff; text-decoration: none; padding: 0.875rem 2.5rem; border-radius: 8px; font-weight: 600; font-size: 0.9375rem; letter-spacing: 0.01em; }
        .btn-container { text-align: center; margin-bottom: 2rem; }
        .footer { padding: 1.5rem 2.5rem; border-top: 1px solid #27272a; font-size: 0.75rem; color: #71717a; text-align: center; }
    </style>
</head>
<body>
<div class="card">
    <div class="header">
        <table>
            <tr>
                <td style="vertical-align:middle;">
                    <div class="company-name">{{ company_name }}</div>
                    {% if company_email %}
                        <div class="company-email">{{ company_email }}</div>
                    {% endif %}
                </td>
                <td style="vertical-align:middle;">
                    <div class="doc-type">QUOTE</div>
                    <div class="doc-number">{{ quote.number }}</div>
                </td>
            </tr>
        </table>
    </div>

    <div class="body">
        <p style="color: #ffffff; font-weight: 500;">Dear {{ quote.customer.name }},</p>
        {% if quote.introText %}
            <p>{{ quote.introText }}</p>
        {% else %}
            <p>Please find your quote attached to this email.</p>
        {% endif %}

        <table class="summary-table">
            <tr>
                <td class="label">Quote number</td>
                <td class="val">{{ quote.number }}</td>
            </tr>
            <tr>
                <td class="label">Issue date</td>
                <td class="val">{{ quote.issuedAt|date('d.m.Y') }}</td>
            </tr>
            {% if quote.validUntil %}
                <tr>
                    <td class="label">Valid until</td>
                    <td class="val">{{ quote.validUntil|date('d.m.Y') }}</td>
                </tr>
            {% endif %}
            <tr class="total-row">
                <td>Total</td>
                <td>{{ quote.grossTotal|number_format(2, '.', ' ') }} {{ quote.currency }}</td>
            </tr>
        </table>

        <p style="margin-bottom: 8px;">If you have any questions, please don't hesitate to reach out.</p>
        <p style="margin-bottom: 0;">Best regards,<br><strong style="color:#ffffff;">{{ company_name }}</strong></p>
    </div>

    <div class="footer">
        {{ company_name }}{% if company_email %} &bull; {{ company_email }}{% endif %}
    </div>
</div>
</body>
</html>
