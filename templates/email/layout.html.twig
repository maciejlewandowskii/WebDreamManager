<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: #09090b; margin: 0; padding: 2rem 1rem; color: #e4e4e7; }
        .card { background: #18181b; max-width: 580px; margin: 0 auto; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.4); border: 1px solid #27272a; }
        .header { background: #18181b; padding: 2rem; border-bottom: 1px solid #27272a; }
        .header table { width: 100%; border-collapse: collapse; }
        .company-name { font-size: 1.125rem; font-weight: 700; color: #ffffff; }
        .company-email { font-size: 0.875rem; color: #a1a1aa; margin-top: 2px; }
        .doc-type { font-size: 1.25rem; font-weight: 700; color: #ffffff; letter-spacing: 0.05em; text-align: right; }
        .doc-number { font-size: 0.875rem; color: #a1a1aa; margin-top: 3px; text-align: right; }
        .body { padding: 2.5rem; }
        p { font-size: 0.9375rem; color: #a1a1aa; line-height: 1.6; margin: 0 0 1.25rem; }
        strong { color: #e4e4e7; }
        h1 { font-size: 1.5rem; font-weight: 700; color: #ffffff; margin: 0 0 1rem; letter-spacing: -0.02em; }
        .summary-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin-bottom: 2rem; border: 1px solid #27272a; overflow: hidden; }
        .summary-table td { padding: 12px 16px; border-bottom: 1px solid #27272a; }
        .summary-table tr:last-child td { border-bottom: none; }
        .summary-table .label { background: #1f1f22; font-weight: 600; color: #e4e4e7; width: 40%; }
        .summary-table .val { color: #a1a1aa; }
        .summary-table .total-row td { border-top: 2px solid #27272a; font-size: 1rem; color: #ffffff; background: #1f1f22; font-weight: 700; }
        .btn { display: inline-block; background: #ffffff; color: #09090b; text-decoration: none; padding: 0.875rem 2.5rem; font-weight: 600; font-size: 0.9375rem; letter-spacing: 0.01em; }
        .btn-container { text-align: center; margin-bottom: 2rem; }
        .secure-text { font-size: 0.75rem; color: #71717a; display: block; margin-top: 8px; }
        .logo { display: inline-flex; align-items: center; gap: 0.625rem; color: #ffffff; font-weight: 700; font-size: 1.125rem; text-decoration: none; }
        .url { font-size: 0.75rem; color: #71717a; word-break: break-all; margin-top: 1rem; }
        .code { font-size: 2rem; font-weight: 700; letter-spacing: 0.25em; color: #ffffff; margin: 0 0 1rem; }
        .footer { padding: 1.5rem 2.5rem; border-top: 1px solid #27272a; font-size: 0.75rem; color: #71717a; text-align: center; }
        {% block email_styles %}{% endblock %}
    </style>
</head>
<body>
<div class="card">
    <div class="header{% block email_header_class %}{% endblock %}">{% block email_header %}{% endblock %}</div>
    <div class="body">{% block email_body %}{% endblock %}</div>
    <div class="footer">{% block email_footer %}{% endblock %}</div>
</div>
</body>
</html>
