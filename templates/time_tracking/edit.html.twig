{% extends 'layout.html.twig' %}

{% block title %}
    {% if record is defined %}Edit Record{% else %}Log Time{% endif %} — WebDream Manager
{% endblock %}

{% block content %}
    {% set breadcrumbs = [{label: 'Time Tracking', url: path('app_time_record_index')}, {label: record is defined ? 'Edit' : 'New'}] %}
    <twig:layout:PageHeader title="{{ record is defined ? 'Edit Time Record' : 'Log Time' }}" :breadcrumbs="breadcrumbs" />

    <div class="page-content">
        <div class="card" style="max-width: 680px;">
            <div class="card-body">
                <twig:time_tracking:TimeRecordForm :recordId="record is defined ? record.id : null" />
            </div>
        </div>
    </div>
{% endblock %}
