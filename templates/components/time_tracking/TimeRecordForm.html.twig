<div {{ attributes }}>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div style="grid-column: 1 / -1;">
            <label class="form-label" for="tr-title">Title *</label>
            <input id="tr-title"
                   type="text"
                   class="form-input"
                   value="{{ title }}"
                   data-model="title"
                   placeholder="What did you work on?">
        </div>

        <div>
            <label class="form-label" for="tr-project">Project *</label>
            <select id="tr-project" class="form-select" data-model="projectId">
                <option value="">— Select project —</option>
                {% for project in this.availableProjects ?? [] %}
                    <option value="{{ project.id }}" {{ projectId == project.id ? 'selected' }}>{{ project.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label class="form-label" for="tr-date">Date *</label>
            <input id="tr-date" type="date" class="form-input" value="{{ date }}" data-model="date">
        </div>

        <div>
            <label class="form-label" for="tr-spent">Spent Hours *</label>
            <input id="tr-spent"
                   type="number"
                   class="form-input"
                   value="{{ spentHours }}"
                   data-model="spentHours"
                   min="0" step="0.25"
                   placeholder="0">
        </div>

        <div>
            <label class="form-label" for="tr-estimated">Estimated Hours</label>
            <input id="tr-estimated"
                   type="number"
                   class="form-input"
                   value="{{ estimatedHours }}"
                   data-model="estimatedHours"
                   min="0" step="0.25"
                   placeholder="Optional">
        </div>

        <div>
            <label class="form-label" for="tr-github">GitHub Issue ID</label>
            <input id="tr-github"
                   type="number"
                   class="form-input"
                   value="{{ githubIssueId }}"
                   data-model="githubIssueId"
                   placeholder="123">
        </div>

        <div style="grid-column: 1 / -1;">
            <label class="form-label" for="tr-description">Description</label>
            <textarea id="tr-description"
                      class="form-textarea"
                      data-model="description"
                      rows="3"
                      placeholder="Details about the work done…">{{ description }}</textarea>
        </div>
    </div>

    <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; justify-content: flex-end;">
        <button type="button" data-action="live#action" data-live-action-param="save" class="btn btn-primary">
            {{ ux_icon('tabler:device-floppy', {class: 'w-4 h-4'}) }}
            Save Record
        </button>
    </div>
</div>
