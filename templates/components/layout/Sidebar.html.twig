<aside class="app-sidebar">
    <div class="sidebar-logo">
        <span>WebDream</span>
        <span style="color: var(--color-on-surface-variant); font-weight: 400;">Manager</span>
    </div>

    <nav class="sidebar-nav">
        <a href="{{ path('app_dashboard') }}"
           class="sidebar-nav-item {{ app.request.get('_route') starts with 'app_dashboard' ? 'active' }}">
            {{ ux_icon('tabler:dashboard', {class: 'w-4 h-4'}) }}
            Dashboard
        </a>

        <div class="sidebar-nav-section">Clients</div>
        <a href="{{ path('app_customer_index') }}"
           class="sidebar-nav-item {{ app.request.get('_route') starts with 'app_customer' ? 'active' }}">
            {{ ux_icon('tabler:users', {class: 'w-4 h-4'}) }}
            Customers
        </a>
        <a href="{{ path('app_project_index') }}"
           class="sidebar-nav-item {{ app.request.get('_route') starts with 'app_project' ? 'active' }}">
            {{ ux_icon('tabler:folder', {class: 'w-4 h-4'}) }}
            Projects
        </a>

        <div class="sidebar-nav-section">Finance</div>
        <a href="{{ path('app_invoice_index') }}"
           class="sidebar-nav-item {{ app.request.get('_route') starts with 'app_invoice' ? 'active' }}">
            {{ ux_icon('tabler:file-invoice', {class: 'w-4 h-4'}) }}
            Invoices
        </a>
        <a href="{{ path('app_quote_index') }}"
           class="sidebar-nav-item {{ app.request.get('_route') starts with 'app_quote' ? 'active' }}">
            {{ ux_icon('tabler:file-text', {class: 'w-4 h-4'}) }}
            Quotes
        </a>

        <div class="sidebar-nav-section">Work</div>
        <a href="{{ path('app_time_record_index') }}"
           class="sidebar-nav-item {{ app.request.get('_route') starts with 'app_time_record' ? 'active' }}">
            {{ ux_icon('tabler:clock', {class: 'w-4 h-4'}) }}
            Time Tracking
        </a>
    </nav>

    <div style="padding: 1rem; border-top: 1px solid var(--color-outline-variant);">
        <div style="font-size: 0.75rem; color: var(--color-on-surface-variant); margin-bottom: 0.5rem;">
            {{ app.user.fullName ?? app.user.email }}
        </div>
        <a href="{{ path('app_logout') }}" class="btn btn-ghost btn-sm" style="width: 100%; justify-content: flex-start;">
            {{ ux_icon('tabler:logout', {class: 'w-4 h-4'}) }}
            Sign out
        </a>
    </div>
</aside>
