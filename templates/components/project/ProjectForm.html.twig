<div {{ attributes }}>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div style="grid-column: 1 / -1;">
            <label class="form-label" for="project-name">Project Name *</label>
            <input id="project-name"
                   type="text"
                   class="form-input"
                   value="{{ name }}"
                   data-model="name"
                   placeholder="Project name">
        </div>

        <div>
            <label class="form-label" for="project-customer">Customer *</label>
            <select id="project-customer" class="form-select" data-model="customerId">
                <option value="">— Select customer —</option>
                {% for customer in this.availableCustomers %}
                    <option value="{{ customer.id }}" {{ customerId == customer.id ? 'selected' }}>
                        {{ customer.name }}{% if customer.company %} ({{ customer.company }}){% endif %}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label class="form-label" for="project-status">Status</label>
            <select id="project-status" class="form-select" data-model="status">
                {% for s in ['planning', 'active', 'on_hold', 'completed', 'cancelled'] %}
                    <option value="{{ s }}" {{ status == s ? 'selected' }}>{{ s|replace({'_': ' '})|capitalize }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label class="form-label" for="project-website">Website URL</label>
            <input id="project-website"
                   type="url"
                   class="form-input"
                   value="{{ websiteUrl }}"
                   data-model="websiteUrl"
                   placeholder="https://client.example.com">
        </div>

        <div>
            <label class="form-label" for="project-github">GitHub Repository</label>
            <input id="project-github"
                   type="text"
                   class="form-input"
                   value="{{ githubRepository }}"
                   data-model="githubRepository"
                   placeholder="owner/repo">
        </div>

        <div style="grid-column: 1 / -1;">
            <label class="form-label" for="project-description">Description</label>
            <textarea id="project-description"
                      class="form-textarea"
                      data-model="description"
                      rows="3"
                      placeholder="Project description…">{{ description }}</textarea>
        </div>
    </div>

    <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; justify-content: flex-end;">
        <button type="button" data-action="live#action" data-live-action-param="save" class="btn btn-primary">
            {{ ux_icon('tabler:device-floppy', {class: 'w-4 h-4'}) }}
            Save Project
        </button>
    </div>
</div>
