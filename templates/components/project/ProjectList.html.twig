<div {{ attributes }}>
    <div style="padding: 1rem 2rem; display: flex; gap: 0.75rem; align-items: center; border-bottom: 1px solid var(--color-outline-variant);">
        <div class="search-wrap" style="flex: 1; max-width: 320px;">
            {{ ux_icon('tabler:search', {class: 'w-4 h-4'}) }}
            <input type="search"
                   class="form-input"
                   placeholder="Search projects…"
                   value="{{ search }}"
                   data-model="search"
                   style="padding-left: 2.25rem;">
        </div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Project</th>
                <th>Customer</th>
                <th>Status</th>
                <th>Budget</th>
                <th>Due</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for project in projects %}
                {% set statusColor = {
                    'planning': 'default',
                    'active': 'success',
                    'on_hold': 'warning',
                    'completed': 'secondary',
                    'cancelled': 'destructive'
                } %}
                <tr>
                    <td>
                        <a href="{{ path('app_project_show', {id: project.id}) }}"
                           style="color: var(--color-on-surface); text-decoration: none; font-weight: 500;">
                            {{ project.name }}
                        </a>
                    </td>
                    <td style="color: var(--color-on-surface-variant);">{{ project.customer.name }}</td>
                    <td>
                        <span class="badge badge-{{ statusColor[project.status.value] ?? 'default' }}">
                            {{ project.status.value|replace({'_': ' '}) }}
                        </span>
                    </td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-on-surface-variant);">
                        {% if project.budget %}{{ project.budget|number_format(0, '.', ' ') }} {{ project.currency }}{% else %}—{% endif %}
                    </td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-on-surface-variant);">
                        {% if project.dueDate %}{{ project.dueDate|date('d.m.Y') }}{% else %}—{% endif %}
                    </td>
                    <td style="text-align: right;">
                        <a href="{{ path('app_project_show', {id: project.id}) }}" class="btn btn-ghost btn-sm">
                            {{ ux_icon('tabler:chevron-right', {class: 'w-4 h-4'}) }}
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" style="text-align: center; padding: 3rem; color: var(--color-on-surface-variant);">
                        No projects found.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
