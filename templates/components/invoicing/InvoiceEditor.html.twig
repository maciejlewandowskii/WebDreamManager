<div {{ attributes }} class="[max-width:900px] [margin:0_auto]">
<fieldset {{ isReadonly ? 'disabled="disabled"' : '' }} class="[border:none] [padding:0] [margin:0]">

    {# Header meta row #}
    <div class="[display:grid] [grid-template-columns:1fr_1fr_1fr] [gap:1rem] [margin-bottom:1.5rem]">
        <div>
            <label class="form-label">Customer *</label>
            <select class="form-select" data-model="customerId">
                <option value="">— Select —</option>
                {% for customer in this.availableCustomers %}
                    <option value="{{ customer.id }}" {{ customerId == customer.id ? 'selected' }}>
                        {{ customer.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="form-label">Project</label>
            <select class="form-select" data-model="projectId">
                <option value="">— None —</option>
                {% for project in this.availableProjects %}
                    <option value="{{ project.id }}" {{ projectId == project.id ? 'selected' }}>
                        {{ project.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="form-label">Currency</label>
            <select class="form-select" data-model="currency">
                {% for c in ['PLN', 'EUR', 'USD', 'GBP'] %}
                    <option value="{{ c }}" {{ currency == c ? 'selected' }}>{{ c }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="form-label">Issue Date</label>
            <input type="date" class="form-input editor-field" value="{{ issuedAt }}" data-model="issuedAt">
        </div>
        <div>
            <label class="form-label">Due Date</label>
            <input type="date" class="form-input editor-field" value="{{ dueAt }}" data-model="dueAt">
        </div>
        <div>
            <label class="form-label">Default Tax Rate %</label>
            <input type="number" class="form-input editor-field" value="{{ defaultTaxRate }}"
                   data-model="defaultTaxRate" min="0" max="100" step="1">
        </div>
    </div>

    {# Line items #}
    <table class="editor-table [margin-bottom:1rem]">
        <thead>
        <tr>
            <th class="[width:42%]">Description</th>
            <th class="[width:12%]">Qty</th>
            <th class="[width:8%]">Unit</th>
            <th class="[width:15%]">Unit price</th>
            <th class="[width:10%]">Tax %</th>
            <th class="[width:10%] text-right">Total net</th>
            <th class="[width:3%]"></th>
        </tr>
        </thead>
        <tbody>
        {% for i, item in items %}
            <tr>
                <td>
                    <input type="text"
                           class="editor-field"
                           value="{{ item.description }}"
                           data-model="items[{{ i }}][description]"
                           placeholder="Service or product description">
                </td>
                <td>
                    <input type="number"
                           class="editor-field"
                           value="{{ item.quantity }}"
                           data-model="items[{{ i }}][quantity]"
                           min="0" step="0.01">
                </td>
                <td>
                    <select class="editor-field"
                            data-model="items[{{ i }}][unit]">
                        <option value="unit" {{ (item.unit ?? 'unit') == 'unit' ? 'selected' }}>unit</option>
                        <option value="h" {{ (item.unit ?? 'unit') == 'h' ? 'selected' }}>h</option>
                        <option value="pcs" {{ (item.unit ?? 'unit') == 'pcs' ? 'selected' }}>pcs</option>
                        <option value="day" {{ (item.unit ?? 'unit') == 'day' ? 'selected' }}>day</option>
                    </select>
                </td>
                <td>
                    <input type="number"
                           class="editor-field"
                           value="{{ item.unitPrice }}"
                           data-model="items[{{ i }}][unitPrice]"
                           min="0" step="0.01">
                </td>
                <td>
                    <input type="number"
                           class="editor-field"
                           value="{{ item.taxRate }}"
                           data-model="items[{{ i }}][taxRate]"
                           min="0" max="100" step="1">
                </td>
                <td class="text-right [padding:0.5rem_0.75rem] [font-family:var(--font-mono)] text-[0.8125rem] [color:var(--color-on-surface-variant)] whitespace-nowrap">
                    {{ (item.quantity * item.unitPrice)|number_format(2, '.', ' ') }}
                </td>
                <td class="text-center">
                    {% if not isReadonly %}
                    <button type="button"
                            data-action="live#action"
                            data-live-action-param="removeItem"
                            data-live-index-param="{{ i }}"
                            class="btn btn-ghost btn-icon [color:var(--color-error)]"
                    >
                        {{ ux_icon('tabler:x', {class: 'w-3 h-3'}) }}
                    </button>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {% if not isReadonly %}
    <button type="button"
            data-action="live#action"
            data-live-action-param="addItem"
            class="btn btn-ghost btn-sm [margin-bottom:1.5rem]"
    >
        {{ ux_icon('tabler:plus', {class: 'w-4 h-4'}) }}
        Add line
    </button>
    {% endif %}

    {# Totals #}
    <div class="editor-totals [max-width:320px] [margin-left:auto]">
        <div class="editor-totals-row">
            <span>Net total</span>
            <span
                class="[font-family:var(--font-mono)]">{{ this.netTotal|number_format(2, '.', ' ') }} {{ currency }}</span>
        </div>
        <div class="editor-totals-row">
            <span>VAT</span>
            <span
                class="[font-family:var(--font-mono)]">{{ this.taxTotal|number_format(2, '.', ' ') }} {{ currency }}</span>
        </div>
        <div class="editor-totals-row gross">
            <span>Gross total</span>
            <span
                class="[font-family:var(--font-mono)]">{{ this.grossTotal|number_format(2, '.', ' ') }} {{ currency }}</span>
        </div>
    </div>

    {# Footer fields #}
    <div
        class="[display:grid] [grid-template-columns:1fr_1fr] [gap:1rem] [margin-top:1.5rem] [padding-top:1.5rem] [border-top:1px_solid_var(--color-outline-variant)]">
        <div>
            <label class="form-label">Bank Account</label>
            <input type="text" class="form-input editor-field" value="{{ bankAccount }}" data-model="bankAccount"
                   placeholder="PL00 0000 0000 …">
        </div>
        <div>
            <label class="form-label">Payment Terms</label>
            <input type="text" class="form-input editor-field" value="{{ paymentTerms }}" data-model="paymentTerms"
                   placeholder="e.g. 14 days net">
        </div>
        <div class="[grid-column:1_/_-1]">
            <label class="form-label">Notes</label>
            <textarea class="form-textarea editor-field" data-model="notes" rows="2"
                      placeholder="Additional notes…">{{ notes }}</textarea>
        </div>
    </div>

    {% if not isReadonly %}
    <div class="[margin-top:1.5rem] flex [gap:0.5rem] [justify-content:flex-end]">
        <button type="button" data-action="live#action" data-live-action-param="save" class="btn btn-primary">
            {{ ux_icon('tabler:device-floppy', {class: 'w-4 h-4'}) }}
            Save Invoice
        </button>
    </div>
    {% endif %}
</fieldset>
</div>
