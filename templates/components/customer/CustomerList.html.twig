<div {{ attributes }}>
    <div class="flex items-center gap-3 border-b border-[var(--color-outline-variant)] px-8 py-4">
        <div class="search-wrap max-w-80 flex-1">
            {{ ux_icon('tabler:search', {class: 'w-4 h-4'}) }}
            <input type="search"
                   class="form-input pl-9"
                   placeholder="Search customers…"
                   value="{{ this.search }}"
                   data-model="debounce(400)|search">
        </div>
    </div>

    <table class="data-table">
        <thead>
        <tr>
            <th>
                <twig:SortableHeader label="Name" field="name" :currentBy="this.sortBy"
                                     :currentDirection="this.sortDirection"/>
            </th>
            <th>
                <twig:SortableHeader label="Company" field="company" :currentBy="this.sortBy"
                                     :currentDirection="this.sortDirection"/>
            </th>
            <th>
                <twig:SortableHeader label="Email" field="email" :currentBy="this.sortBy"
                                     :currentDirection="this.sortDirection"/>
            </th>
            <th>
                <twig:SortableHeader label="Status" field="status" :currentBy="this.sortBy"
                                     :currentDirection="this.sortDirection"/>
            </th>
            <th>Projects</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        {% for customer in this.customers %}
            <tr>
                <td>
                    <a href="{{ path('app_customer_show', {id: customer.id}) }}"
                       class="font-medium text-[var(--color-on-surface)] no-underline">
                        {{ customer.name }}
                    </a>
                </td>
                <td class="text-[var(--color-on-surface-variant)]">{{ customer.company ?? '—' }}</td>
                <td class="font-mono text-[0.8125rem] text-[var(--color-on-surface-variant)]">{{ customer.email ?? '—' }}</td>
                <td>
                    <span class="badge badge-{{ customer.status.color() }}">
                        {{ customer.status.label() }}
                    </span>
                </td>
                <td class="text-[var(--color-on-surface-variant)]">{{ customer.projects|length }}</td>
                <td class="text-right">
                    <a href="{{ path('app_customer_show', {id: customer.id}) }}" class="btn btn-ghost btn-sm">
                        {{ ux_icon('tabler:chevron-right', {class: 'w-4 h-4'}) }}
                    </a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="p-12 text-center text-[var(--color-on-surface-variant)]">
                    No customers found.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <twig:Pagination :page="this.page" :totalPages="this.totalPages" :total="this.total" label="customers" labelSingular="customer" />
</div>
