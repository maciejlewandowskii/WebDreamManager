<div {{ attributes.defaults({'data-action': 'role:mutated@document->live#$render'}) }}>
    <div class="flex items-center gap-3 border-b border-[var(--color-outline-variant)] px-8 py-4">
        <div class="search-wrap max-w-80 flex-1">
            {{ ux_icon('tabler:search', {class: 'w-4 h-4'}) }}
            <input type="search"
                   class="form-input pl-9"
                   placeholder="Search roles…"
                   value="{{ this.search }}"
                   data-model="debounce(400)|search"
            >
        </div>
    </div>

    <table class="data-table">
        <thead>
        <tr>
            <th>
                <twig:SortableHeader label="Name" field="name" :currentBy="this.sortBy" :currentDirection="this.sortDirection"/>
            </th>
            <th>Permissions</th>
            <th>
                <twig:SortableHeader label="Type" field="isSystem" :currentBy="this.sortBy" :currentDirection="this.sortDirection"/>
            </th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        {% for role in this.roles %}
            <tr>
                <td class="font-medium">
                    {{ role.name }}
                </td>
                <td class="[color:var(--color-on-surface-variant)] text-sm">
                    {{ role.permissions|length }} permission{{ role.permissions|length != 1 ? 's' }}
                </td>
                <td>
                    {% if role.isSystem %}
                        <span class="badge badge-warning">System</span>
                    {% else %}
                        <span class="badge badge-default">Custom</span>
                    {% endif %}
                </td>
                <td class="text-right flex items-center justify-end [gap:0.25rem]">
                    {% if is_granted('role.update') %}
                        <a href="{{ path('app_admin_role_edit', {id: role.id}) }}"
                           class="btn btn-ghost btn-sm"
                           data-turbo-frame="modal"
                           data-modal-title="{{ role.isSystem ? 'View Role — ' ~ role.name : 'Edit Role — ' ~ role.name }}">
                            {{ role.isSystem
                                ? ux_icon('tabler:eye', {class: 'w-4 h-4'})
                                : ux_icon('tabler:pencil', {class: 'w-4 h-4'})
                            }}
                        </a>
                    {% endif %}
                    {% if is_granted('role.delete') and not role.isSystem %}
                        <form method="post" action="{{ path('app_admin_role_delete', {id: role.id}) }}"
                              data-controller="delete-confirm"
                              data-delete-confirm-message-value="Delete role {{ role.name }}?"
                              data-delete-confirm-event-value="role:mutated"
                              data-action="submit->delete-confirm#submit">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete_role_' ~ role.id) }}">
                            <button type="submit" class="btn btn-ghost btn-sm [color:var(--color-error)]">
                                {{ ux_icon('tabler:trash', {class: 'w-4 h-4'}) }}
                            </button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="p-12 text-center text-[var(--color-on-surface-variant)]">
                    No roles found.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <twig:Pagination :page="this.page" :totalPages="this.totalPages" :total="this.total" label="roles" labelSingular="role" />
</div>
