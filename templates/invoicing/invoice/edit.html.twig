{% extends 'layout.html.twig' %}

{% block title %}
    {% if invoice is defined %}Edit {{ invoice.number }}{% else %}New Invoice{% endif %} — WebDream Manager
{% endblock %}

{% block content %}
    {% set breadcrumbs = [{label: 'Invoices', url: path('app_invoice_index')}, {label: invoice is defined ? invoice.number : 'New'}] %}
    <twig:layout:PageHeader title="{{ invoice is defined ? invoice.number : 'New Invoice' }}" :breadcrumbs="breadcrumbs" />

    <div class="page-content">
        <twig:invoicing:InvoiceEditor :invoiceId="invoice is defined ? invoice.id : null" />
    </div>
{% endblock %}
