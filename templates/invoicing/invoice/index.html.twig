{% extends 'layout.html.twig' %}

{% block title %}Invoices — WebDream Manager{% endblock %}

{% block content %}
    {% set actions %}
        <a href="{{ path('app_invoice_new') }}" class="btn btn-primary">
            {{ ux_icon('tabler:plus', {class: 'w-4 h-4'}) }}
            New Invoice
        </a>
    {% endset %}
    <twig:layout:PageHeader title="Invoices" :actions="actions" />

    <table class="data-table">
        <thead>
            <tr>
                <th>Number</th>
                <th>Customer</th>
                <th>Issued</th>
                <th>Due</th>
                <th>Net</th>
                <th>Gross</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for invoice in invoices %}
                <tr>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; white-space: nowrap;">
                        <a href="{{ path('app_invoice_edit', {id: invoice.id}) }}"
                           style="color: var(--color-on-surface); text-decoration: none; font-weight: 500;">{{ invoice.number }}</a>
                    </td>
                    <td>{{ invoice.customer.name }}</td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-on-surface-variant);">{{ invoice.issuedAt|date('d.m.Y') }}</td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-on-surface-variant);">{{ invoice.dueAt|date('d.m.Y') }}</td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-on-surface-variant);">{{ invoice.netTotal|number_format(2, '.', ' ') }}</td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 500;">{{ invoice.grossTotal|number_format(2, '.', ' ') }} {{ invoice.currency }}</td>
                    <td><span class="badge badge-{{ invoice.status.color }}">{{ invoice.status.value }}</span></td>
                    <td style="text-align: right;">
                        <a href="{{ path('app_invoice_edit', {id: invoice.id}) }}" class="btn btn-ghost btn-sm">
                            {{ ux_icon('tabler:pencil', {class: 'w-4 h-4'}) }}
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" style="text-align: center; padding: 3rem; color: var(--color-on-surface-variant);">
                        No invoices yet.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
