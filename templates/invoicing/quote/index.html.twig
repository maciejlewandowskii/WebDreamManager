{% extends 'layout.html.twig' %}

{% block title %}Quotes — WebDream Manager{% endblock %}

{% block content %}
    {% set actions %}
        <a href="{{ path('app_quote_new') }}" class="btn btn-primary">
            {{ ux_icon('tabler:plus', {class: 'w-4 h-4'}) }}
            New Quote
        </a>
    {% endset %}
    <twig:layout:PageHeader title="Quotes" :actions="actions" />

    <table class="data-table">
        <thead>
            <tr>
                <th>Number</th>
                <th>Customer</th>
                <th>Issued</th>
                <th>Valid Until</th>
                <th>Gross</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for quote in quotes %}
                <tr>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; white-space: nowrap;">
                        <a href="{{ path('app_quote_edit', {id: quote.id}) }}"
                           style="color: var(--color-on-surface); text-decoration: none; font-weight: 500;">{{ quote.number }}</a>
                    </td>
                    <td>{{ quote.customer.name }}</td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-on-surface-variant);">{{ quote.issuedAt|date('d.m.Y') }}</td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-on-surface-variant);">
                        {% if quote.validUntil %}{{ quote.validUntil|date('d.m.Y') }}{% else %}—{% endif %}
                    </td>
                    <td style="font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 500;">{{ quote.grossTotal|number_format(2, '.', ' ') }} {{ quote.currency }}</td>
                    <td><span class="badge badge-{{ quote.status.color }}">{{ quote.status.value }}</span></td>
                    <td style="text-align: right;">
                        <a href="{{ path('app_quote_edit', {id: quote.id}) }}" class="btn btn-ghost btn-sm">
                            {{ ux_icon('tabler:pencil', {class: 'w-4 h-4'}) }}
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" style="text-align: center; padding: 3rem; color: var(--color-on-surface-variant);">
                        No quotes yet.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
