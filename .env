###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme_generate_a_real_secret_here
APP_SHARE_DIR=var/share
APP_DOMAIN=manager.localhost
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://manager.localhost
###< symfony/routing ###

###> symfony/mailer ###
