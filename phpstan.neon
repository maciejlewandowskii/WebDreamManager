parameters:
    level: 9
    paths:
        - src
    excludePaths:
        - src/Kernel.php
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
    doctrine:
        objectManagerLoader: tests/bootstrap_doctrine.php
    ignoreErrors:
        - '#type mapping mismatch: database can contain Symfony\\Component\\Uid\\Uuid but property expects string#'
        - '#parameter .* with no value type specified in iterable type iterable#'


