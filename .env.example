# WebDream Manager — production environment
# Copy this file to .env.prod and fill in all values before starting.

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=prod
APP_SECRET=          # generate: openssl rand -hex 32
APP_DOMAIN=          # e.g. manager.yourdomain.com
WEBAUTHN_RP_ID=      # same as APP_DOMAIN
APP_VERSION=latest
GITHUB_REPO=maciejlewandowskii/WebDreamManager

# ── Caddy ─────────────────────────────────────────────────────────────────────
# SERVER_NAME must match APP_DOMAIN
SERVER_NAME=         # e.g. manager.yourdomain.com
DEFAULT_URI=         # e.g. https://manager.yourdomain.com
CADDY_SERVER_EXTRA_DIRECTIVES=tls /etc/caddy/certs/cf-origin.pem /etc/caddy/certs/cf-origin.key

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=manager
POSTGRES_USER=app
POSTGRES_PASSWORD=   # generate: openssl rand -hex 24
DATABASE_URL=        # postgresql://app:PASSWORD@database:5432/manager?serverVersion=16&charset=utf8

# ── Mercure ───────────────────────────────────────────────────────────────────
MERCURE_URL=http://php/.well-known/mercure
MERCURE_PUBLIC_URL=  # e.g. https://manager.yourdomain.com/.well-known/mercure
MERCURE_JWT_SECRET=         # generate: openssl rand -hex 32
MERCURE_PUBLISHER_JWT_KEY=  # same as MERCURE_JWT_SECRET
MERCURE_SUBSCRIBER_JWT_KEY= # same as MERCURE_JWT_SECRET

# ── Mailer ───────────────────────────────────────────────────────────────────
MAILER_DSN=smtp://user:pass@smtp.example.com:587
MAILER_FROM=noreply@yourdomain.com
MAILER_FROM_NAME="WebDream Manager"
COMPANY_NAME=
COMPANY_ADDRESS=

# ── Two-Factor Auth ──────────────────────────────────────────────────────────
TWO_FACTOR_ENCRYPTION_KEY=   # generate: openssl rand -base64 32

# ── Stripe (optional) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Twilio SMS (optional) ────────────────────────────────────────────────────
TWILIO_DSN=
TWILIO_FROM_NUMBER=

# ── Google Calendar (optional) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI= # e.g. https://manager.yourdomain.com/auth/google/callback
