# WebDream Manager — production environment
# Copy this file to .env and fill in all values before starting.

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=prod
APP_SECRET=          # generate: openssl rand -hex 32
APP_DOMAIN=          # e.g. manager.yourdomain.com
WEBAUTHN_RP_ID=      # same as APP_DOMAIN
APP_VERSION=latest
GITHUB_REPO=maciejlewandowskii/WebDreamManager

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_VERSION=16
POSTGRES_DB=manager
POSTGRES_USER=app
POSTGRES_PASSWORD=   # generate: openssl rand -hex 24

# ── Caddy / Mercure ──────────────────────────────────────────────────────────
CADDY_MERCURE_JWT_SECRET=   # generate: openssl rand -hex 32

# ── Mailer ───────────────────────────────────────────────────────────────────
MAILER_DSN=smtp://user:pass@smtp.example.com:587
MAILER_FROM=noreply@yourdomain.com
MAILER_FROM_NAME="WebDream Manager"
COMPANY_NAME=
COMPANY_ADDRESS=

# ── Two-Factor Auth ──────────────────────────────────────────────────────────
TWO_FACTOR_ENCRYPTION_KEY=   # generate: openssl rand -base64 32

# ── Stripe (optional) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Twilio SMS (optional) ────────────────────────────────────────────────────
TWILIO_DSN=
TWILIO_FROM_NUMBER=

# ── Google Calendar (optional) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://${APP_DOMAIN}/auth/google/callback
